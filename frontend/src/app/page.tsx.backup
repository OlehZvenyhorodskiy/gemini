"use client";

import { useState, useEffect, useRef, useCallback, useMemo } from "react";
import { HandLandmarker, FilesetResolver } from "@mediapipe/tasks-vision";

/**
 * WebSocket protocol message types — strictly typed to keep
 * everything in check at compile time.
 */
interface ServerMessage {
    type: "audio" | "text" | "image" | "status" | "tool_call" | "tool_result" | "error";
    content?: string;
    data?: string;
    mime?: string;
    state?: "listening" | "thinking" | "speaking" | "interrupted";
    session_id?: string;
    mode?: string;
    message?: string;
    name?: string;
    args?: Record<string, unknown>;
    result?: Record<string, unknown>;
}

interface ChatMessage {
    id: string;
    role: "user" | "agent";
    type: "text" | "image" | "tool" | "error";
    content: string;
    imageData?: string;
    imageMime?: string;
    toolName?: string;
    toolArgs?: Record<string, unknown>;
    toolResult?: Record<string, unknown>;
    timestamp: Date;
}

/**
 * All supported mode slugs — the 3 original ones plus 8 new specialized modes.
 * Each maps to a base mode on the backend (live, creative, or navigator),
 * but with tailored system instructions.
 */
type AgentMode =
    | "live" | "creative" | "navigator"
    | "code" | "research" | "language" | "data"
    | "music" | "game" | "meeting" | "security";

type AgentState = "listening" | "thinking" | "speaking" | "interrupted" | "disconnected";
type ThemeMode = "dark" | "light" | "midnight" | "sunset" | "ocean" | "forest" | "custom";

const ALL_THEMES: ThemeMode[] = ["dark", "light", "midnight", "sunset", "ocean", "forest"];

/** Swatch colors for the theme picker UI */
interface ThemePreset {
    label: string;
    bg: string;
    accent: string;
}

const THEME_PRESETS: Record<ThemeMode, ThemePreset> = {
    dark: { label: "Dark", bg: "#0f0f13", accent: "#4285F4" },
    light: { label: "Light", bg: "#f8f9fa", accent: "#4285F4" },
    midnight: { label: "Midnight", bg: "#08081a", accent: "#8a64ff" },
    sunset: { label: "Sunset", bg: "#1a0f08", accent: "#ff9540" },
    ocean: { label: "Ocean", bg: "#081a20", accent: "#40e0d0" },
    forest: { label: "Forest", bg: "#0a1a0f", accent: "#4ccb68" },
    custom: { label: "Custom", bg: "#1a1a24", accent: "#4285F4" },
};

const WS_URL = process.env.NEXT_PUBLIC_WS_URL || "ws://localhost:8080/ws";

/**
 * Mode metadata — icon, label, description, and a color accent.
 * These are displayed as experiment cards a la Google Labs.
 */
interface ModeInfo {
    label: string;
    emoji: string;
    description: string;
    accent: string;
}

